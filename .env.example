# PostgreSQL (docker-compose default)
DATABASE_URL="postgresql://boatapp:boatapp@localhost:5432/boatapp?schema=public"

# JWT signing secret (generate a long random string in production)
JWT_SECRET="change-me-to-a-long-random-secret-at-least-32-chars"

# Public URL of the app (used for Stripe redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe test keys — https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Stripe webhook signing secret — https://dashboard.stripe.com/test/webhooks
# For local testing: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET="whsec_..."

# Optional: platform service fee as decimal fraction (default 0.10 = 10%)
PLATFORM_SERVICE_FEE_RATE="0.10"
